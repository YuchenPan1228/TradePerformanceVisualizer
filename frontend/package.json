{
  "name": "portfolio-dashboard",
  "version": "1.0.0",
  "private": true,
  "proxy": "http://localhost:5001",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "lucide-react": "^0.263.1",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:frontend": "react-scripts start",
    "start:backend": "cd ../backend && ./venv/bin/python app.py",
    "dev": "concurrently -n \"backend,frontend\" -c \"blue,green\" \"npm run start:backend\" \"wait-on http://localhost:5001/api/health && npm run start:frontend\"",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}



